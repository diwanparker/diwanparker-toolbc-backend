{
  "ConnectionStrings": {
    "Default": "Host=<supabase-host>;Port=6543;Database=postgres;Username=<supabase-user>;Password=<supabase-password>;Ssl Mode=Require;Trust Server Certificate=true"
  },
  "Database": {
    "ApplyMigrationsOnStartup": false,
    "SeedDemoData": false
  },
